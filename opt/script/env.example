# Copy to /opt/script/env and fill in (chmod 600). Sourced by run-with-otel.sh.
# Splunk Observability (OTLP traces + metrics from the Splunk Python distro)
export SPLUNK_REALM="us1"
export SPLUNK_ACCESS_TOKEN="REPLACE_O11Y_ACCESS_TOKEN"

# Splunk Cloud HEC
export SPLUNK_HEC_URL="https://http-inputs-example.splunkcloud.com/services/collector/event"
export SPLUNK_HEC_TOKEN="REPLACE_HEC_TOKEN"
export SPLUNK_HEC_INDEX="main"
export SPLUNK_HEC_SOURCE="oci:metrics-bridge-vm"

# OCI Monitoring (API key auth — configure ~/.oci/config on this VM)
export OCI_CONFIG_FILE="${OCI_CONFIG_FILE:-/root/.oci/config}"
export OCI_CONFIG_PROFILE="${OCI_CONFIG_PROFILE:-DEFAULT}"

# Compartment to list/summarize metrics (often tenancy OCID if using subtree)
export METRICS_COMPARTMENT_OCID="ocid1.compartment.oc1..REPLACE"
export LIST_METRICS_IN_SUBTREE="false"

# Optional tuning
export MAX_METRICS_PER_INVOKE="75"
export OCI_METRICS_WINDOW_MINUTES="5"
export LOG_LEVEL="INFO"

# JSON run log (overwritten each execution)
export BRIDGE_JSON_LOG="/opt/script/logs/last-run.json"

# HEC event host field (defaults to hostname if unset)
# export SPLUNK_HEC_HOST="my-gcp-bridge"

# OpenTelemetry (override if needed; run-with-otel.sh sets sensible defaults)
# export OTEL_SERVICE_NAME="oci-metrics-bridge-vm"
# export OTEL_RESOURCE_ATTRIBUTES="deployment.environment=gcp-lab,service.namespace=oci-bridge"
